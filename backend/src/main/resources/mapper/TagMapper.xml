<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.example.fanxing.mapper.TagMapper">

    <select id="selectTagNamesByNoteId" resultType="java.lang.String">
        SELECT t.name
        FROM tag t
                 JOIN note_tag_rel r ON t.id = r.tag_id
        WHERE r.note_id = #{noteId}
    </select>

</mapper>