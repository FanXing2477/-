<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.example.fanxing.mapper.NoteSharePermissionMapper">

    <!-- 判断是否有查看和编辑权限 -->
    <select id="existsPermission" resultType="org.example.fanxing.entity.NoteSharePermission">
        select note_id, user_id, permission_type
        from note_share_permission
        where note_id = #{noteId}
          and user_id = #{userId}
            limit 1
    </select>


</mapper>